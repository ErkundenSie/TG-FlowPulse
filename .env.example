# Telegram API 凭证（可选）
# 如果不设置，将使用内置默认配置；也可以在 WebUI 系统设置中配置
# 如需使用自己的凭证，从 https://my.telegram.org 获取
# TG_API_ID=your_api_id_here
# TG_API_HASH=your_api_hash_here

# 应用密钥（必须！）
# 使用随机字符串，例如: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=your_secret_key_here
ADMIN_PASSWORD=your_admin_password_here
TZ=Asia/Shanghai

# 可选配置
HOST_PORT=8080
PORT=8080
APP_DATA_DIR=/data
# 允许跨域访问的前端来源，多个用英文逗号分隔；单容器同源部署通常无需修改
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080

# 面板 2FA TOTP 时间窗口容差（默认 0，仅当前 30s；可设 1 表示允许前后各 1 个窗口）
# APP_TOTP_VALID_WINDOW=1

# Telegram Session 模式（默认 file）
# TG_SESSION_MODE=file
# TG_SESSION_NO_UPDATES=0
# TG_GLOBAL_CONCURRENCY=1
